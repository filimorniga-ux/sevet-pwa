# Meta WhatsApp Business API — Variables de entorno
# Copia este archivo como .env y llena los valores reales

# Token permanente del System User (o token temporal para pruebas)
META_ACCESS_TOKEN=tu_token_aqui

# ID de la cuenta de WhatsApp Business (WABA ID)
# Se obtiene en: developers.facebook.com > Tu App > WhatsApp > Configuración de la API
WABA_ID=229745983408226

# ID del número de teléfono registrado
PHONE_NUMBER_ID=1006914325847395

# Versión de la Graph API
GRAPH_API_VERSION=v22.0
